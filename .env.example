# Copy this file to .env and fill in your values before running docker compose up

# PostgreSQL password for the miniflux database user
MINIFLUX_DB_PASSWORD=change_me_strong_password

# Miniflux admin UI password
MINIFLUX_ADMIN_PASSWORD=change_me_strong_password

# Your public Miniflux domain (used for link generation)
MINIFLUX_BASE_URL=https://miniflux.yourdomain.com
